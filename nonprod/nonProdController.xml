<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:ora="http://www.oracle.com/xml/ns/dbchangelog-ext"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd"
>
  <!-- Development Properties -->
  <!-- <include
    relativeToChangelogFile="true"
    file="development_properties.sql"
  /> -->

  <!-- Product sert -->
  <includeAll
    relativeToChangelogFile="true"
    errorIfMissingOrEmpty="false"
    path="sert/db/_dba"
  />
  <include
    relativeToChangelogFile="true"
    file="sert/db/sert_core/schemaController.xml"
  />
  <include
    relativeToChangelogFile="true"
    file="sert/db/sert_pub/schemaController.xml"
  />

  <include
    relativeToChangelogFile="true"
    file="sert/db/unit_test/schemaController.xml"
  />
  <include
    context="@apex"
    relativeToChangelogFile="true"
    file="sert/apex/apexController.xml"
  />
  <includeAll
    relativeToChangelogFile="true"
    errorIfMissingOrEmpty="false"
    path="sert/db/post_install"
  />
</databaseChangeLog>
